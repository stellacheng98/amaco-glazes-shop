# Copy to .env and fill in. Never commit .env.
# Keys come from the Stripe Dashboard → Developers → API keys:
# https://dashboard.stripe.com/test/apikeys
# Use the test-mode keys until you are ready to take real money.

# Secret key — server-side only, never in browser code or a commit. Required for
# checkout. To keep it off disk entirely, leave this blank and export it instead:
#   export STRIPE_SECRET_KEY=sk_test_...
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Publishable key — safe to expose. Not used by the current redirect-based
# checkout; needed only if the payment form moves on-site (Elements / embedded).
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# From `stripe listen` locally, or Dashboard → Developers → Webhooks in production.
# Without it the server cannot verify that webhooks really came from Stripe.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# Public origin used to build Checkout return URLs.
# In production set this to your real domain, e.g. https://shop.example.com
PUBLIC_URL=http://localhost:4242

PORT=4242

# Where the SQLite database lives. Defaults to ./shop.db next to server.js.
# In production point this at a persistent disk so the catalog and orders
# survive redeploys — many hosts wipe the local filesystem on each deploy.
# DATABASE_PATH=/data/shop.db
